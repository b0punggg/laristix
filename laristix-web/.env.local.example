# Leave empty so requests go through Next.js proxy (same origin as localhost:3000)
NEXT_PUBLIC_API_URL=

# Laravel backend used by Next.js rewrites (server-side only)
BACKEND_URL=http://laristix.test

# Midtrans (Snap) — public client key for frontend Snap.js
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

NEXT_PUBLIC_APP_URL=http://localhost:3000
